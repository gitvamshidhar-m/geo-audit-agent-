# GEMINI_API_KEY: Required for Gemini AI API calls.
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# OPENAI_API_KEY: Required for OpenAI GPT-4 API calls.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# ANTHROPIC_API_KEY: Required for Anthropic Claude API calls.
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# GROQ_API_KEY: Required for Groq API calls.
GROQ_API_KEY="MY_GROQ_API_KEY"

# HUGGINGFACE_API_KEY: Required for Hugging Face API calls.
HUGGINGFACE_API_KEY="MY_HUGGINGFACE_API_KEY"

# DEEPSEEK_API_KEY: Required for DeepSeek API calls.
DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"

# PERPLEXITY_API_KEY: Required for Perplexity API calls.
PERPLEXITY_API_KEY="MY_PERPLEXITY_API_KEY"

# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"
